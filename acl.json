{
  "tagOwners": {
    "tag:admin":   ["autogroup:owner"],
    "tag:dns":     ["autogroup:owner"],
    "tag:monitor": ["autogroup:owner"]
  },

  "acls": [
    {
      "action": "accept",
      "src":    ["tag:admin"],
      "dst":    ["10.0.0.0/24:*"]
    },
    {
      "action": "accept",
      "src":    ["tag:dns"],
      "dst":    ["10.0.0.5:53"]
    },
    {
      "action": "accept",
      "src":    ["tag:monitor"],
      "dst":    [
        "10.0.0.21:3000",
        "10.0.0.21:9090",
        "10.0.0.21:9093"
      ]
    },
    {
      "action": "accept",
      "src":    ["autogroup:member"],
      "dst":    ["autogroup:self:*"]
    }
  ],

  "ssh": [
    {
      "action": "accept",
      "src":    ["tag:admin"],
      "dst":    ["tag:admin"],
      "users":  ["autogroup:nonroot", "root"]
    }
  ],

  "tests": [
    {
      "src":    "tag:admin",
      "accept": ["10.0.0.10:22", "10.0.0.22:8000"]
    },
    {
      "src":    "tag:dns",
      "accept": ["10.0.0.5:53"],
      "deny":   ["10.0.0.10:22", "10.0.0.21:3000"]
    },
    {
      "src":    "tag:monitor",
      "accept": ["10.0.0.21:3000", "10.0.0.21:9090"],
      "deny":   ["10.0.0.10:22", "10.0.0.5:53"]
    }
  ]
}
